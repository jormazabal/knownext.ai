{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KnowNext.ai",
  "version": "0.3.0",
  "identifier": "ai.knownext.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "KnowNext.ai",
        "width": 1536,
        "height": 1024,
        "minWidth": 1160,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
